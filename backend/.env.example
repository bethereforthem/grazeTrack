# ─── Server Configuration ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT Configuration ───────────────────────────────────────────
# IMPORTANT: Change both secrets to long random strings in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRE=7d

# ─── Admin JWT (separate secret for admin tokens — more secure) ───
ADMIN_JWT_SECRET=your_admin_super_secret_change_this_in_production
ADMIN_TOKEN_EXPIRY=7d

# ─── Firebase Configuration ──────────────────────────────────────
# Get these from Firebase Console > Project Settings > Service Accounts
# Download the service account JSON and place it at: src/config/serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── CORS Configuration ──────────────────────────────────────────
# Set this to your Flutter app's URL in production
CORS_ORIGIN=*
